# .env.example — copy to .env and fill in your values
# Do NOT commit .env to version control.
#
# First-time setup: run `.venv/bin/notebooklm login --browser-cookies chrome`
# to extract cookies from Chrome. Requires `rookiepy` (included in requirements.txt).

# ── SMTP Settings (required) ─────────────────────────────────────────────────
# Gmail example: smtp.gmail.com / 587 (STARTTLS) or 465 (SSL)
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password-here

# ── Email Addresses (required) ───────────────────────────────────────────────
SENDER_EMAIL=you@gmail.com
RECIPIENT_EMAIL=you@gmail.com

# ── YouTube Data API (REQUIRED) ──────────────────────────────────────────────
# Used for duration-based Shorts filtering (videos < 3 minutes are excluded).
# Get a free key at: https://console.cloud.google.com → APIs → YouTube Data API v3
# Daily quota (10,000 units) is more than enough for weekly processing.
YOUTUBE_API_KEY=your-api-key-here

# ── Local File Paths (optional, defaults shown) ──────────────────────────────
CHANNELS_FILE=channels.json
STATE_FILE=state.json

# ── NotebookLM Browser Settings (optional, defaults shown) ───────────────────
# Which browser's cookies database to extract cookies from.
# Options: chrome, firefox, opera, edge, chromium, vivaldi, safari (macOS only)
NOTEBOOKLM_BROWSER=chrome
