# Dockerfile.test — Autonomous GUI Sandbox Test Environment for TubeLM
FROM ubuntu:22.04

# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive
ENV DISPLAY=:99

# Install system packaging GUI dependencies, Xvfb, window manager, Python, and packaging tools
RUN apt-get update && apt-get install -y \
    xvfb \
    fluxbox \
    libgtk-3-0 \
    libappindicator3-1 \
    gir1.2-appindicator3-0.1 \
    xdg-utils \
    curl \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    x11-utils \
    dpkg-dev \
    && rm -rf /var/lib/apt/lists/*

# Install official Google Chrome stable (snap-free, native binary!)
RUN curl -sS -o /tmp/chrome.deb https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb && \
    apt-get update && apt-get install -y /tmp/chrome.deb && \
    rm -rf /tmp/chrome.deb /var/lib/apt/lists/*

# Create workspace directories
WORKDIR /app

# Copy the entire codebase to build inside container
COPY . /app/src

# Build the Debian package inside the container to align with container's GLIBC (highly backwards-compatible!)
WORKDIR /app/src
RUN bash desktop/scripts/build_linux_deb.sh

# Install the TubeLM native Debian package we compiled inside the container!
RUN apt-get update && apt-get install -y /app/src/desktop/dist/tubelm_1.0.0_amd64.deb && rm -rf /var/lib/apt/lists/*

# Setup virtual python environment for running tests
RUN python3 -m venv /app/test_venv && \
    /app/test_venv/bin/pip install --upgrade pip && \
    /app/test_venv/bin/pip install playwright requests

# Configure Playwright to use host Chromium
ENV PLAYWRIGHT_BROWSERS_PATH=/usr/bin

# Copy the backwards-compatible debian build to the mounted volume, then start virtual display and execute tests
CMD ["sh", "-c", "mkdir -p /app/summaries && cp /app/src/desktop/dist/tubelm_1.0.0_amd64.deb /app/summaries/tubelm_1.0.0_amd64_compat.deb && Xvfb :99 -screen 0 1280x800x24 & sleep 2 && fluxbox & sleep 2 && /app/test_venv/bin/python3 /app/src/desktop/scripts/test_gui_e2e.py"]
